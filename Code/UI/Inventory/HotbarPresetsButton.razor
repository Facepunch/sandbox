@using Sandbox;
@using Sandbox.UI;
@namespace Sandbox
@inherits Panel

<root>

    <div class="presets-toggle" @onclick=@OnToggleClick>
        <i>expand_less</i>
    </div>

    @if ( _dropdownOpen )
    {
        <div class="presets-dropdown">

            @{
                var presets = PlayerInventory.GetLoadoutPresets();
            }

            @if ( presets.Count == 0 )
            {
                <div class="presets-empty">No saved hotbars</div>
            }

            @foreach ( var preset in presets )
            {
                var name = preset.Name;
                var json = preset.LoadoutJson;
                <div class="preset-item" @onclick=@(() => OnLoadPreset( json ))>
                    <span class="preset-label">@name</span>
                    <div class="preset-delete" onclick:stopPropagation=@true @onclick=@(() => OnDeletePreset( name ))>
                        <i>close</i>
                    </div>
                </div>
            }

            <div class="presets-separator"></div>

            <div class="preset-save-new" @onclick=@OnSaveNew>
                <i>add</i>
                <span>Save As New Hotbar</span>
            </div>

        </div>
    }

</root>

@code
{
    public PlayerInventory Inventory { get; set; }

    bool _dropdownOpen;

    public override void Tick()
    {
        base.Tick();

        // Close the dropdown if the spawn menu is closed
        if ( _dropdownOpen )
        {
            var host = Game.ActiveScene.Get<SpawnMenuHost>();
            if ( !(host?.Panel?.HasClass( "open" ) ?? false) )
            {
                CloseDropdown();
            }
        }
    }

    void CloseDropdown()
    {
        _dropdownOpen = false;
        StateHasChanged();
    }

    void OnToggleClick()
    {
        _dropdownOpen = !_dropdownOpen;
        StateHasChanged();
    }

    void OnLoadPreset( string json )
    {
        if ( !Inventory.IsValid() ) return;
        Inventory.SwitchToPreset( json );
        CloseDropdown();
    }

    void OnDeletePreset( string name )
    {
        PlayerInventory.DeleteLoadoutPreset( name );
        StateHasChanged();
    }

    void OnSaveNew()
    {
        CloseDropdown();

        var popup = new StringQueryPopup
        {
            Title = "Save Hotbar",
            Placeholder = "Enter a name...",
            ConfirmLabel = "Save",
            OnConfirm = OnSaveConfirmed,
            Parent = FindRootPanel()
        };
    }

    void OnSaveConfirmed( string name )
    {
        // The active loadout is always kept up-to-date in the cookie by SaveLoadout(),
        // so we can snapshot it here without any host round-trip.
        if ( !Game.Cookies.TryGetString( PlayerInventory.LoadoutCookieKey, out var json ) || string.IsNullOrEmpty( json ) )
            return;

        PlayerInventory.SaveLoadoutPreset( name, json );
    }
}
