@using Sandbox;
@using Sandbox.UI;
@inherits UtilityPage
@namespace Sandbox
@attribute [Icon( "🚧" )]
@attribute [Title( "Limits" )]
@attribute [Order( 0 )]
@attribute [UtilityOf( typeof(LimitsFunction) )]

<root class="page" style="flex-direction: column;">
    @foreach ( var info in GetLimitConVars() )
    {
        var isHost = Connection.Local.IsHost;
        if ( info.IsBool )
        {
            <div class="control-row">
                <label class="left">@info.Label</label>
                <Checkbox Value=@((bool)info.Prop.GetValue( null )) ValueChanged=@((bool v) => ConsoleSystem.Run($"{info.Name} {(v ? 1 : 0)}")) disabled=@(!isHost) />
            </div>
        }
        else
        {
            var limit = GameLimitsSystem.GetLimit( info.Category );
            var current = GameLimitsSystem.GetLocalCount( info.Category );
            var pct = limit > 0 ? (float)current / limit : 0f;
            var fillClass = pct >= 1f ? "at-limit" : pct >= 0.75f ? "near-limit" : "ok";
            var widthPct = (int)(MathF.Min( pct, 1f ) * 100f);

            <div class="control-row">
                <label class="left">@info.Label</label>
                <div class="limit-bar-track">
                    <div class="limit-bar-fill @fillClass" style="width: @(widthPct)%;"></div>
                </div>
                <span class="limit-count">@current / @limit</span>
            </div>

            if ( isHost )
            {
                var range = info.Prop.GetCustomAttribute<RangeAttribute>();
                float min = range?.Min ?? 0f;
                float max = range?.Max ?? 1000f;
                float step = info.Prop.GetCustomAttribute<StepAttribute>()?.Step ?? 1f;

                <div class="control-row limit-slider-row">
                    <SliderControl ShowRange=@(true) Value=@(Convert.ToSingle(info.Prop.GetValue(null)))
                                   Min=@min Max=@max Step=@step
                                   OnValueChanged=@((float v) => ConsoleSystem.Run( $"{info.Name} {(int)v}" )) />
                </div>
            }
        }
    }
</root>

@code
{
    record ConVarInfo( string Name, string Label, bool IsBool, PropertyDescription Prop, string Category );

    protected override int BuildHash() => HashCode.Combine(
        GameLimitsSystem.GetLocalCount( LimitCategory.Prop ),
        GameLimitsSystem.GetLocalCount( LimitCategory.Entity ),
        GameLimitsSystem.GetLocalCount( LimitCategory.Thruster ),
        GameLimitsSystem.GetLocalCount( LimitCategory.Balloon ),
        GameLimitsSystem.GetLocalCount( LimitCategory.Wheel ),
        GameLimitsSystem.GetLocalCount( LimitCategory.Constraint )
    );

    IEnumerable<ConVarInfo> GetLimitConVars()
    {
        var td = TypeLibrary.GetType( typeof(GameLimitsSystem) );
        if ( td is null ) yield break;

        foreach ( var prop in td.Properties.OrderBy( p => p.Name ) )
        {
            var convar = prop.GetCustomAttribute<ConVarAttribute>();
            if ( convar is null ) continue;

            var label = prop.Title ?? prop.Name;
            var isBool = prop.PropertyType == typeof(bool);
            var category = GameLimitsSystem.GetCategoryForConVar( convar.Name );

            yield return new ConVarInfo( convar.Name, label, isBool, prop, category );
        }
    }
}
