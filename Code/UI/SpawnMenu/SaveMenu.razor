@using Sandbox;
@using Sandbox.UI;
@namespace Sandbox
@inherits Panel
@attribute [SpawnMenuHost.SpawnMenuMode<SpawnMenuHost.HostOnly>]
@attribute [Icon( "💾" )]
@attribute [Title( "Saves" )]
@attribute [Order( 150 )]

<root>
    <div class="save-window">
        <div class="save-header">
            <span>💾 Saves</span>
            <div class="save-tabs">
                <div class="save-tab @(ActiveTab == "local" ? "active" : "")" @onclick='@(() => ActiveTab = "local")'>Local</div>
                <div class="save-tab @(ActiveTab == "cloud" ? "active" : "")" @onclick='@(() => ActiveTab = "cloud")'>Cloud</div>
            </div>
        </div>

        <div class="body">
            @if ( ActiveTab == "local" )
            {
                @if ( !Collection.Entries.Any( e => e.IsEditable ) )
                {
                    <div class="empty-state">No saves yet.</div>
                }
                @foreach ( var entry in Collection.Entries.Where( e => e.IsEditable ) )
                {
                    var s = entry;
                    <div class="save-card"
                         @onclick="@(() => ConfirmLoad( s ))"
                         @onmousedown="@((PanelEvent e) => OnCardMouseDown( s, e ))">
                        @if ( s.StorageEntry.Thumbnail != null )
                        {
                            <div class="save-thumb" style="background-image: url(@s.StorageEntry.Thumbnail);"></div>
                        }
                        <div class="save-info @(s.StorageEntry.Thumbnail == null ? "save-info--padded" : "")">
                            <label class="save-name">@s.Title</label>
                            @if ( !string.IsNullOrEmpty( s.Timestamp ) )
                            {
                                <label class="save-timestamp">@s.Timestamp</label>
                            }
                        </div>
                        <div class="save-dots">⋮</div>
                    </div>
                }
            }
            else
            {
                @if ( !Collection.Entries.Any( e => !e.IsEditable ) )
                {
                    <div class="empty-state">No cloud saves for this map.</div>
                }
                @foreach ( var entry in Collection.Entries.Where( e => !e.IsEditable ) )
                {
                    var s = entry;
                    <div class="save-card"
                         @onclick="@(() => ConfirmLoad( s ))"
                         @onmousedown="@((PanelEvent e) => OnCardMouseDown( s, e ))">
                        @if ( s.StorageEntry.Thumbnail != null )
                        {
                            <div class="save-thumb" style="background-image: url(@s.StorageEntry.Thumbnail);"></div>
                        }
                        <div class="save-info @(s.StorageEntry.Thumbnail == null ? "save-info--padded" : "")">
                            <label class="save-name">@s.Title</label>
                            @if ( !string.IsNullOrEmpty( s.Timestamp ) )
                            {
                                <label class="save-timestamp">@s.Timestamp</label>
                            }
                        </div>
                        <div class="save-dots">⋮</div>
                    </div>
                }
            }
        </div>

        <div class="footer">
            <TextEntry @ref="SaveNameEntry" Placeholder="Save name..." @onsubmit="@OnSave"></TextEntry>
            <button @onclick="@OnSave">💾 Save</button>
        </div>
    </div>
</root>

@code
{
    TextEntry SaveNameEntry;
    string ActiveTab = "local";

    public SaveCollection Collection { get; } = new();

    protected override void OnAfterTreeRender( bool firstTime )
    {
        if ( firstTime )
        {
            Collection.Changed += StateHasChanged;
            Collection.Refresh();
        }
    }

    void OnCardMouseDown( SaveCollection.Entry save, PanelEvent e )
    {
        if ( e is MousePanelEvent { MouseButton: MouseButtons.Right } me )
        {
            me.StopPropagation();
            var menu = MenuPanel.Open( this );
            menu.AddOption( "download", "Load Save", () => ConfirmLoad( save ) );
            if ( save.IsEditable )
                menu.AddOption( "publish", "Publish", () => SaveData.Publish( save.StorageEntry ) );
            menu.AddOption( "delete", save.IsEditable ? "Delete" : "Remove", () =>
            {
                if ( save.IsEditable )
                    Collection.Delete( save.StorageEntry );
                else
                    Collection.Uninstall( save.WorkshopId );
            } );
        }
    }

    void ConfirmLoad( SaveCollection.Entry save )
    {
        var popup = new StringQueryPopup
        {
            Title = "Load Save",
            Prompt = $"Load \"{save.Title}\"? Unsaved changes will be lost.",
            ConfirmLabel = "Load",
            ShowInput = false,
            OnConfirm = _ => DoLoad( save ),
            Parent = FindPopupPanel()
        };
    }

    void DoLoad( SaveCollection.Entry save ) { _ = SaveSystem.Current.LoadFromEntry( save.StorageEntry ); }

    void OnSave()
    {
        var saveName = SaveNameEntry?.Text?.Trim();
        if ( string.IsNullOrEmpty( saveName ) )
            return;

        var now = DateTime.Now;
        var timestamp = now.ToString( "yyyy-MM-dd HH:mm:ss" );

        Bitmap thumbnail = null;
        var camera = Game.ActiveScene?.Camera;
        if ( camera.IsValid() )
        {
            thumbnail = new Bitmap( 256, 144 );
            camera.RenderToBitmap( thumbnail );
        }

        var entry = SaveData.Create( saveName, timestamp, SaveSystem.Current?.MapIdent, thumbnail );
        SaveSystem.Current?.SaveToEntry( entry );

        SaveNameEntry.Text = "";
        Collection.Refresh();
    }
}
