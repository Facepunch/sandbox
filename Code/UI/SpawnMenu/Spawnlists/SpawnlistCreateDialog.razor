@using Sandbox;
@using Sandbox.UI;
@inherits Panel
@namespace Sandbox

<div class="spawnlist-create-dialog">
    <h3>Create Spawnlist</h3>
    <p>Give your new spawnlist a name.</p>
    <TextEntry class="menu-input" Placeholder="Spawnlist name..." Value:bind=@Name />
    <Button Text="Create" Icon="add" class="menu-action primary wide" Disabled=@( string.IsNullOrWhiteSpace( Name ) ) @onclick=@OnCreate />
</div>

@code
{
    SpawnlistsPage ParentPage;

    public SpawnlistCreateDialog( SpawnlistsPage parentPage )
    {
        ParentPage = parentPage;
    }

    string Name { get; set; } = "";

    void OnCreate()
    {
        if ( string.IsNullOrWhiteSpace( Name ) ) return;

        SpawnlistData.Create( Name.Trim() );
        Name = "";

        ParentPage?.RefreshList();
    }
}

